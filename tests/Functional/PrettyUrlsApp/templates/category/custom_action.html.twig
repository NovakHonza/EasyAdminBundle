{# this temaplte tests that the admin URL generator works as expected when using pretty URLs #}
<span id="url1">{{ ea_url() }}</span>
<span id="url2">{{ ea_url().set('page', 2) }}</span>
<span id="url3">{{ ea_url().setAction('new') }}</span>
<span id="url4">{{ ea_url().setController('EasyCorp\\Bundle\\EasyAdminBundle\\Tests\\Functional\\PrettyUrlsApp\\Controller\\BlogPostCrudController').setAction('index') }}</span>
<span id="url5">{{ ea_url().setDashboard('EasyCorp\\Bundle\\EasyAdminBundle\\Tests\\Functional\\PrettyUrlsApp\\Controller\\SecondDashboardController') }}</span>
<span id="url6">{{ ea_url()
    .setDashboard('EasyCorp\\Bundle\\EasyAdminBundle\\Tests\\Functional\\PrettyUrlsApp\\Controller\\SecondDashboardController')
    .setController('EasyCorp\\Bundle\\EasyAdminBundle\\Tests\\Functional\\PrettyUrlsApp\\Controller\\UserCrudController')
    .setAction('detail')
    .setEntityId(3)
}}</span>
